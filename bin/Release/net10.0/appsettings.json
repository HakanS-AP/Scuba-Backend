{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "AdminSettings": {
    // Never put the real key here. Set it in Azure App Settings:
    //   Key name:  AdminSettings__Key
    //   Value:     <your secret password>
    "Key": ""
  },
  "CorsOrigins": {
    // Set these in Azure App Settings (no code change needed when domains change):
    //   CorsOrigins__Public__0  =  https://<public-app>.azurewebsites.net
    //   CorsOrigins__Admin__0   =  https://<admin-app>.azurewebsites.net
    // Add __1, __2, ... entries for extra origins (custom domains, staging, etc.)
    "Public": [],
    "Admin":  []
  }
}
